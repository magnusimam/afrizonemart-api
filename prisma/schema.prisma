// Prisma schema — Afrizonemart 2.0
// Generates a typed Prisma Client used by the modules in src/modules/**.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// Auth / Identity domain
// -----------------------------------------------------------------

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
  /// Per-user-permissions account. Effective access is whatever's in
  /// `User.permissions[]`. Use STAFF for interns / contractors / scoped
  /// employees who shouldn't have full ADMIN rights.
  STAFF
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  /// Optional E.164 phone (e.g. "+2348012345678"). Set by SMS auth flow.
  phone            String?  @unique
  /// Google subject id when the account was first linked via Google OAuth.
  /// We store it so we can identify the same Google user across email
  /// changes. Null for password-only or phone-only users.
  googleId         String?  @unique
  /// Picture URL from the OAuth provider — handy for avatars.
  avatarUrl        String?
  role             UserRole @default(CUSTOMER)
  /// Per-user capabilities (only used when role=STAFF). When role=ADMIN
  /// this is ignored — ADMIN always has every capability. CUSTOMER and
  /// SELLER also ignore this. List values come from the capability
  /// registry in src/lib/permissions.ts.
  permissions      String[] @default([])
  /// Free-form job title for staff (e.g. "Intern", "Customer Support",
  /// "Content Editor"). Cosmetic only — does NOT grant access; the
  /// permissions array drives what they can do. Surfaced in the admin
  /// staff list and on the staff member's dashboard greeting.
  jobTitle         String?
  // Refresh tokens are hashed before storage so a DB leak doesn't grant
  // session access. Null when the user has logged out everywhere.
  refreshTokenHash String?
  /// Phase 11.3 (audit M7) — per-account lockout counters. Defends
  /// against IP-rotating credential stuffing where the global rate
  /// limiter (which keys on IP) doesn't see the same attacker hitting
  /// one account from many addresses. Counter resets on successful
  /// login, or rolls forward when the last failure was outside the
  /// 15-minute window.
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  lockedUntil         DateTime?
  /// 2026-05-16 — Phase 2 gamification. Date-only birth date; used
  /// by the birthday-bonus cron to award tier-scaled coins on the
  /// customer's birth-month. Captured via /account/profile after
  /// they've opted in; never required.
  birthDate           DateTime?
  /// 2026-05-16 — Phase 2 gamification. Stable referral slug
  /// assigned on signup. Used by the share link
  /// `https://afrizonemart.com/?ref=<code>`. Indexed below for
  /// the attribution lookup.
  referralCode        String?   @unique
  /// 2026-05-16 — points at the User who referred this account. Set
  /// during signup when ?ref=<code> is present and the code matches
  /// an existing user. Null for organic / direct signups.
  referredByUserId    String?
  referredBy          User?     @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers       User[]    @relation("UserReferrals")
  referralsMade       Referral[] @relation("ReferralReferrer")
  referralsReceived   Referral[] @relation("ReferralReferee")
  /// Tracker #48 — marketing consent flags. NDPR / GDPR foundation
  /// for every campaign + automation flow built on top of this.
  /// Defaults to false; existing users not grandfathered. Customer
  /// can flip both from /account/profile, OR via the signed
  /// one-click unsubscribe link in any marketing email.
  /// `marketingOptIn` gates email campaigns. `smsOptIn` is the
  /// future SMS / WhatsApp channel mirror — when the SMS provider
  /// is wired, this is the column it gates on.
  marketingOptIn      Boolean   @default(false)
  smsOptIn            Boolean   @default(false)
  /// 2026-06-05 — Play Store compliance: in-app account deletion.
  /// Set the moment a user invokes DELETE /api/auth/me. Their PII
  /// (email, name, phone, avatar) is anonymised in the same write
  /// so this column is mostly a marker for "tombstoned user — do
  /// not surface in admin lists, do not send marketing." Orders +
  /// reviews stay linked by userId so accounting + review
  /// integrity is preserved; only the user's identity fields are
  /// scrubbed. A future 30-day cron hard-deletes the row + cascades.
  deletedAt           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cart           Cart?
  orders         Order[]
  redemptions    CouponRedemption[]
  blogPosts      BlogPost[]         @relation("BlogPostAuthor")
  uploadedAssets MediaAsset[]       @relation("MediaAssetUploader")
  pageRevisions  PageRevision[]     @relation("PageRevisionAuthor")
  /// Products assigned to this user as part of the intern image-
  /// update workflow. Reassignment moves products in/out of this list.
  assignedProducts        Product[]                @relation("ProductInternAssignee")
  /// Image-update submissions this user has made (intern role).
  internSubmissions       ProductImageSubmission[] @relation("InternSubmissionAuthor")
  /// Image-update submissions this user has approved or rejected
  /// (admin/reviewer role).
  reviewedSubmissions     ProductImageSubmission[] @relation("InternSubmissionReviewer")
  /// Payouts received as the intern contractor — one row per payday
  /// covering many approved submissions.
  payoutsReceived         InternPayout[]           @relation("InternPayoutContractor")
  /// Payouts this user created in the admin UI.
  payoutsCreated          InternPayout[]           @relation("InternPayoutCreator")
  /// Full-product submissions this user has drafted (intern role).
  productSubmissions      ProductSubmission[]      @relation("ProductSubmissionAuthor")
  /// Full-product submissions this user has reviewed (reviewer role).
  reviewedProductSubmissions ProductSubmission[]   @relation("ProductSubmissionReviewer")
  /// Saved delivery addresses. The first one a customer creates is
  /// implicitly default; subsequent edits to `isDefault` are exclusive
  /// (only one address per user can be default at a time — enforced
  /// in the addresses service, not the schema).
  addresses               UserAddress[]            @relation("UserAddresses")
  /// Customer wishlist — heart on PDP / product card adds a row,
  /// removes it on toggle. Surfaces on /account/wishlist.
  wishlist                WishlistItem[]           @relation("UserWishlist")
  /// Product views the customer has logged via the PDP dwell tracker.
  /// SetNull on user delete so we keep aggregate trending counts even
  /// after an account is wiped.
  productViews            ProductView[]
  /// Audit trail of price changes this user has made. Read-only
  /// from the User side; writes happen via applyPriceChange().
  priceChanges            ProductPriceChange[]     @relation("PriceChangedBy")
  /// Continental Rewards account — 1:1, auto-created on first
  /// paid order. Null until enrollment.
  loyaltyAccount          LoyaltyAccount?          @relation("UserLoyalty")
  /// Mobile push notification tokens registered to this user. One
  /// row per device; sign-out deletes the row. Send path iterates
  /// every row to fan out a single notification to all the
  /// customer's devices.
  pushTokens              PushToken[]
  /// 2026-06-05 — product reviews authored by this user. SetNull
  /// on user delete so review text survives (other shoppers
  /// benefit) but the row is decoupled for anonymisation.
  reviews                 Review[]                 @relation("UserReviews")

  @@index([email])
  @@index([phone])
  @@index([referredByUserId])
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

/// Per-device push notification token. One row per (user, token)
/// pair — upsert on (token) since Expo regenerates the token on app
/// reinstalls but the same device may flip between users (family
/// sharing a tablet).
///
/// The send path picks `lastUsedAt` as the freshness signal — when
/// it's older than 30 days the token is considered stale and we
/// stop sending to it (FCM/APNs would 410-Gone anyway; this saves
/// the round trip).
model PushToken {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// The Expo push token (`ExponentPushToken[...]`). Globally unique
  /// — if another user signs in on the same device, the row is
  /// re-assigned to them via upsert-on-token.
  token       String       @unique
  platform    PushPlatform
  /// Updated on every successful send so we can prune stale tokens
  /// without waiting for a delivery 410.
  lastUsedAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())

  @@index([userId])
}

// -----------------------------------------------------------------
// Catalog domain (Principle #7 DDD: products belong to the products
// module on the application side; the schema mirrors the domain).
// -----------------------------------------------------------------

/// Visual archetype that drives the per-category PDP treatment on
/// the mobile app (and reserved for future web theming). Set by admin
/// per category. Defaults to FASHION (the safest neutral layout).
/// See `afrizonemart-mobile/src/lib/categoryArchetype.ts` for what
/// each archetype renders on PDP — solid amber tile (GROCERY),
/// gradient (FASHION), navy (WINE), warm cream (LIFESTYLE).
enum CategoryArchetype {
  GROCERY
  WINE
  LIFESTYLE
  FASHION
}

model Category {
  id        String            @id @default(cuid())
  slug      String            @unique
  name      String
  image     String?
  parentId  String?
  parent    Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[]        @relation("CategoryTree")
  products  Product[]
  /// Drives the mobile PDP archetype routing.
  archetype CategoryArchetype @default(FASHION)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([parentId])
}

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  brand            String?
  shortDescription String?  @db.Text
  description      String?  @db.Text
  ingredients      String?  @db.Text
  // Money values in Naira (whole units). Was previously documented as kobo
  // but the seed and frontend formatter both treat these as Naira.
  price            Int
  comparePrice     Int?
  discountPercent  Int?
  origin           String? // 2-letter ISO country code, e.g. "NG", "KE"
  /// Phase 11 — shipping weight in kilograms. Used by the shipping
  /// quote algorithm to pick the right weight bracket. Nullable so
  /// existing rows don't break; the quote engine treats null as
  /// 0.5 kg by default (small package).
  weightKg         Float?
  inStock          Boolean  @default(true)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  // Image URLs as a JSON array — flexible without a side table for now.
  images           String[]
  /// Brand / company logo URL. Per-product (not per-brand) for now —
  /// when 50 products from the same brand all set this, that's a hint
  /// to extract a proper Brand table. Captured by the intern image
  /// workflow alongside front/back/side; surfaced in the storefront's
  /// "About the brand" section on the product page.
  brandImageUrl    String?
  brandImageAlt    String?
  // Schema-Driven attributes (Principle #4): bundles, features, specs,
  // variants, aboutTitle/body/image — anything that varies by product
  // type without needing a column per attribute.
  attributes       Json     @default("{}")

  categoryId String?
  category   Category?          @relation(fields: [categoryId], references: [id])
  reviews    Review[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  placements ProductPlacement[]
  /// Tracker #45 — bundles are now first-class SKU rows. Every product
  /// has at least one variant (auto-seeded on create or by migration
  /// for legacy rows). The cart + order line item refers to a variant,
  /// not directly to a product, so the customer's selected pack-size +
  /// its price + its stock all survive into the order.
  variants   ProductVariant[]

  /// Intern assignment for the bulk image-update workflow. The named
  /// intern owns this product's image slot until reassigned. Null when
  /// the product is in the unassigned pool (admin can bulk-assign or
  /// an intern can claim from it).
  assignedInternId   String?
  assignedIntern     User?                    @relation("ProductInternAssignee", fields: [assignedInternId], references: [id], onDelete: SetNull)
  imageSubmissions   ProductImageSubmission[]
  wishlistedBy       WishlistItem[]
  /// Append-only dwell-time view log — powers the trending sort on
  /// /api/products?sort=trending and the "For You" feed. A 90-day
  /// retention cron prunes old rows.
  views              ProductView[]
  /// Append-only audit trail of every price change. Every write
  /// path (inline edit, bulk re-price, CSV import, scheduled
  /// flip, manual single-product save, revert) routes through
  /// `applyPriceChange()` which appends a row here in the same
  /// transaction as the Product update.
  priceChanges       ProductPriceChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([origin])
  @@index([assignedInternId])
}

model Review {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// 2026-06-05 — added so we can (a) dedupe reviews per (user,
  /// product) and (b) anonymise a deleted user's reviews
  /// retroactively. Nullable for historical rows written before
  /// this column existed; the partial-unique index below
  /// only enforces the constraint on non-null values.
  userId        String?
  user          User?    @relation("UserReviews", fields: [userId], references: [id], onDelete: SetNull)
  authorName    String
  authorCountry String? // 2-letter ISO
  rating        Int
  title         String?
  body          String   @db.Text
  verified      Boolean  @default(false)
  /// 2026-06-08 — soft-delete flag for moderation. Hidden reviews
  /// are excluded from the public listProductReviews endpoint AND
  /// from the product-rating aggregate (so a hidden 1-star
  /// review doesn't drag the displayed average down). Admin can
  /// flip + unflip; hard-delete remains available for truly
  /// abusive content where we want the row gone for good.
  hidden        Boolean  @default(false)
  /// Why ops hid this review — short audit string. Surfaced on
  /// the admin row so the next person doesn't re-unhide blind.
  hiddenReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

/// Append-only product view log. Powers the trending sort + future
/// "recently viewed" / collaborative-filter signals. One row per
/// meaningful dwell (mobile PDP fires after ~2s on screen, deduped
/// per (sessionId, productId) for 5 minutes on the API).
///
/// Retention: a cron prunes rows older than 90 days so the table
/// stays bounded. Loss of 90+ day-old data is fine — trending only
/// reads the last 7 days, and recent-viewed only the last 30.
model ProductView {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Null for anonymous viewers — trending counts everyone but the
  /// per-user "recently viewed" surface ignores rows without a user.
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Anonymous session identifier (opaque UUID minted on first app
  /// launch, stored client-side). Used for dedup so a single device's
  /// reload-spam doesn't inflate trending counts. Not PII.
  sessionId  String?
  viewedAt   DateTime @default(now())

  @@index([productId, viewedAt])
  @@index([userId, viewedAt])
  @@index([sessionId, viewedAt])
}

// -----------------------------------------------------------------
// Commerce domain — Cart + Orders
// -----------------------------------------------------------------

model Cart {
  id                  String     @id @default(cuid())
  userId              String     @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items               CartItem[]
  // Currently-applied coupon. Carries through cart edits so a user
  // can change quantities without losing their discount. Re-validated
  // at place-order time.
  couponId            String?
  coupon              Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  // Phase Audit.9 — set the moment we send a recovery email so we don't
  // re-spam the user. Cleared whenever the cart is modified.
  abandonedNotifiedAt DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([updatedAt, abandonedNotifiedAt])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  /// Tracker #45 — every CartItem points at a ProductVariant. Two
  /// cart lines for the same product but different variants are
  /// distinct rows (the uniqueness key below is on variant, not
  /// product). Live pricing reads from the variant; snapshot still
  /// happens at order time.
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  /// Display-only label for freeform variants the customer picked
  /// (e.g. "Red", "Large"). Doesn't affect pricing/stock — those
  /// live on the variant row itself.
  variantLabel String?
  // Cart items reference current Product rows for live pricing. Snapshot
  // happens at order time, not cart time.
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productVariantId])
  @@index([productId])
  @@index([productVariantId])
}

/// Tracker #45 — first-class SKU row. Each Product has one or more
/// variants; the default variant captures the product's base price
/// and serves products that don't expose bundle choices. Bundle
/// selectors on the PDP are rendered straight from this table.
model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Bundle label as shown on the PDP — "1 Pack", "Carton (12)",
  /// "Default" for products without bundles.
  label         String
  /// Price in Naira (whole units). The cart + order code reads from
  /// here; Product.price is only used as the fallback for legacy
  /// reads + as the default-variant seed.
  priceNgn      Int
  /// Optional compare-at (strikethrough) price.
  comparePriceNgn Int?
  /// How many product units this variant represents (a "Carton (12)"
  /// has unitsPerPack = 12). Defaults to 1 for plain SKUs.
  unitsPerPack  Int     @default(1)
  /// Per-variant stock toggle. Mirrors the product's overall inStock
  /// for now; lays groundwork for true per-SKU inventory later.
  inStock       Boolean @default(true)
  /// Display ordering on the PDP bundle selector.
  sortOrder     Int     @default(0)
  /// True for the auto-seeded "1 unit" / "Default" variant created
  /// when the product has no bundles. Used by product-create paths
  /// to know whether to update the seed or add a new row.
  isDefault     Boolean @default(false)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([productId, sortOrder])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  FULFILLING
  SHIPPED
  /// 2026-06-04 — Show & Scan delivery confirmation. Set when ops
  /// hands the parcel to the rider. Customer's app shows the QR /
  /// OTP on this status; rider scan flips it to DELIVERED.
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  PAYSTACK
  GTSQUAD
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  INITIATED
  SUCCEEDED
  FAILED
  REVERSED
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Which gateway processed this attempt. 'stub' is used in dev until
  // real GT Squad keys are wired.
  gateway     String
  // Gateway's own reference for reconciliation + webhook lookup.
  gatewayRef  String        @unique
  amount      Int
  currency    String
  status      PaymentStatus @default(INITIATED)
  // Redirect URL the customer is sent to (gateway-hosted page).
  checkoutUrl String?
  // Full request/response body — useful when debugging gateway weirdness.
  rawPayload  Json          @default("{}")
  settledAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([orderId])
  @@index([gatewayRef])
}

model Order {
  id           String      @id @default(cuid())
  // Short, user-facing order number — generated at create time.
  orderNumber  String      @unique
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  status       OrderStatus @default(PENDING_PAYMENT)
  // Money in Naira (whole units), snapshot at order time.
  subtotal     Int
  shippingCost Int         @default(0)
  total        Int
  currency     String      @default("NGN")

  // Shipping address snapshot
  shipFullName    String
  shipPhone       String
  shipAddressLine String
  shipCity        String
  shipCountry     String // 2-letter ISO

  paymentMethod PaymentMethod @default(PAYSTACK)
  // External payment reference (gateway txn id) once payment succeeds.
  paymentRef    String?

  // Mirror of sum(refunds.amount) — kept in sync via service layer so
  // we can render "₦X refunded of ₦Y" without aggregating on every read.
  refundedTotal Int       @default(0)
  cancelledAt   DateTime?

  /// 2026-06-04 — Show & Scan delivery confirmation. The signed JWT
  /// the customer's app shows as a QR; the 6-digit OTP derived
  /// from it (so the rider can type instead of scan). Both rotate
  /// when ops re-flips status to OUT_FOR_DELIVERY. Cleared on
  /// DELIVERED. See `modules/courier/tokens.ts`.
  deliveryToken     String?
  deliveryOtp       String?
  /// Who confirmed the delivery — populated when status becomes
  /// DELIVERED. Used by the auto-mark backstop to decide whether
  /// to show the review prompt (skip when 'auto').
  deliveredSource   String?
  /// Timestamp delivery was confirmed. Mirrors the OrderEvent
  /// createdAt for the DELIVERED transition; denormed so the
  /// orders list can show "Delivered Jun 4, 14:32" without a join.
  deliveredAt       DateTime?

  // Coupon snapshot at order time (code + discount in Naira). The full
  // coupon record is referenced via CouponRedemption for usage-cap
  // accounting; this snapshot is for display.
  couponCode     String?
  couponDiscount Int     @default(0)

  /// Continental Rewards (Tracker #44 PR 3) — coins the customer
  /// redeemed against this order. `coinDiscount` is the resulting
  /// NGN discount applied to the order total. Stored separately
  /// from `couponDiscount` so the order summary can break out the
  /// two discount lines independently, and so PR 4's refund
  /// clawback can return the exact number of coins paid.
  coinsRedeemed  Int     @default(0)
  coinDiscount   Int     @default(0)

  // Selected shipping rate at order time (nullable for legacy orders
  // placed before Phase 4 landed).
  shippingRateId String?
  shippingRate   ShippingRate? @relation(fields: [shippingRateId], references: [id])
  /// Phase 11 — which shipping provider produced the quote that was
  /// chosen at checkout. Defaults to 'manual' (our flat-rate-by-zone
  /// engine). When carrier APIs land in Phase 2 this becomes 'gig',
  /// 'dhl', etc., so fulfilment knows which carrier to actually book.
  shippingProvider String? @default("manual")

  items       OrderItem[]
  events      OrderEvent[]
  refunds     Refund[]
  redemptions CouponRedemption[]
  payments    Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum OrderEventType {
  STATUS_CHANGED
  NOTE
  PAYMENT_RECEIVED
  SHIPMENT_UPDATED
  REFUND_RECORDED
  CANCELLED
}

model OrderEvent {
  id                String         @id @default(cuid())
  orderId           String
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type              OrderEventType
  // Free-form structured payload — e.g. { from: 'PAID', to: 'SHIPPED' }
  // for STATUS_CHANGED, { text: '...' } for NOTE, { amount, reason }
  // for REFUND_RECORDED. Kept JSON so adding event types stays cheap.
  payload           Json           @default("{}")
  // The admin user who triggered the event. Null for system-emitted
  // events (e.g. webhook-driven status changes).
  actorUserId       String?
  // Whether this event should be visible to the customer in their
  // order timeline. Private staff notes default false.
  isCustomerVisible Boolean        @default(false)
  createdAt         DateTime       @default(now())

  @@index([orderId])
}

enum RefundStatus {
  RECORDED // Admin marked refund; gateway call not yet made
  SETTLED // Gateway confirmed money returned
  FAILED // Gateway rejected or reversed
}

model Refund {
  id              String       @id @default(cuid())
  orderId         String
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Amount in the order's currency (Naira whole units for NGN orders).
  amount          Int
  reason          String?
  status          RefundStatus @default(RECORDED)
  // Gateway refund reference once SETTLED.
  gatewayRef      String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([orderId])
}

// -----------------------------------------------------------------
// Discounts (Phase 4)
// -----------------------------------------------------------------

enum CouponType {
  PERCENT_CART // valuePercent off the cart subtotal
  FIXED_CART // valueAmount off the cart subtotal
  FREE_SHIPPING // forces shippingCost to 0
}

model Coupon {
  id                 String     @id @default(cuid())
  // Stored uppercase. Apply is case-insensitive (uppercased before lookup).
  code               String     @unique
  description        String?
  type               CouponType
  // Exactly one of these is meaningful per type — service enforces it.
  valuePercent       Int? // 1-100 for PERCENT_CART
  valueAmount        Int? // Naira whole units for FIXED_CART
  minSubtotal        Int? // require cart subtotal ≥ this
  maxUses            Int? // total uses across all customers
  maxUsesPerCustomer Int? // per-customer cap
  /// 2026-05-16 — tier-gated coupons. When set, only customers whose
  /// LoyaltyAccount.currentTier is >= this tier can apply the
  /// coupon. Null = unrestricted (the default).
  requiredTier       LoyaltyTier?
  startsAt           DateTime?
  endsAt             DateTime?
  isActive           Boolean    @default(true)
  // Denormalized count for cheap list-view rendering. Source of truth
  // is `redemptions.count` — we keep this in sync via the service.
  usageCount         Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  redemptions CouponRedemption[]
  carts       Cart[]

  @@index([code])
  @@index([isActive])
}

model CouponRedemption {
  id               String   @id @default(cuid())
  couponId         String
  coupon           Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountDiscounted Int
  createdAt        DateTime @default(now())

  @@index([couponId])
  @@index([userId, couponId])
  @@index([orderId])
}

// -----------------------------------------------------------------
// Shipping (Phase 4) — replaces hardcoded ₦1500 / free-over-₦10k.
// -----------------------------------------------------------------

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  // ISO-2 country codes covered by this zone, e.g. ["NG"], ["KE","TZ","UG"].
  // Empty array = wildcard (matches any country); used together with
  // isDefault for the catch-all "Rest of world" zone.
  countries String[]
  /// Phase 11 — optional sub-country zone restriction. When non-empty
  /// the zone only matches when the destination city (case-insensitive)
  /// is in this list AND the country also matches. Empty list = whole
  /// country zone. Lets us carve out flagship cities (Lagos, Nairobi,
  /// Joburg) with their own rates without splitting the country up.
  cities    String[]       @default([])
  isDefault Boolean        @default(false)
  sortOrder Int            @default(0)
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isDefault])
}

model ShippingRate {
  id              String       @id @default(cuid())
  zoneId          String
  zone            ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name            String
  // Naira whole units (matches order/product money convention).
  priceAmount     Int          @default(0)
  // Free above this subtotal threshold. Null = never auto-free.
  freeAboveAmount Int?
  /// Phase 11 — weight bracket this rate covers (in kilograms). The
  /// rate matches when cart total weight falls in [minWeightKg,
  /// maxWeightKg]. Null on either side = unbounded. Multiple bracket
  /// rows per zone cover the weight curve.
  minWeightKg     Float?
  maxWeightKg     Float?
  /// Phase 11 — delivery ETA shown to the customer at checkout.
  /// Inclusive range; "3-5 days".
  etaDaysMin      Int          @default(3)
  etaDaysMax      Int          @default(7)
  isDefault       Boolean      @default(false)
  sortOrder       Int          @default(0)
  orders          Order[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([zoneId])
}

// User backref for CouponRedemption (added separately to keep User
// model declaration tidy when scrolling).
//
// (Prisma requires the relation field on both sides; we add it on User
// at top-level via the `redemptions` field below.)

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  /// Tracker #45 — variant the customer actually bought. Optional
  /// only for legacy rows backfilled by the variants migration; new
  /// orders always set this.
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  /// Snapshot of the bundle label at order time so reading the
  /// order in five years still tells you which pack-size shipped.
  bundleLabel  String?
  /// Display-only freeform variant label (size/colour) selected
  /// at add-to-cart time.
  variantLabel String?
  /// How many product units one of these line items represents at
  /// the time of order. Future fulfillment math (e.g. "ship 24
  /// bottles") leans on this rather than re-reading a mutable
  /// ProductVariant.
  unitsPerPack Int     @default(1)
  // Snapshot the product fields so historical orders are stable even if
  // the catalog changes (price, name, image).
  productSlug  String
  productName  String
  productImage String?
  unitPrice    Int
  quantity     Int
  lineTotal    Int

  @@index([orderId])
  @@index([productVariantId])
  @@index([productId])
}

// -----------------------------------------------------------------
// Settings (Phase 5) — store-wide key/value config edited from admin.
// `value` is JSON so a setting can be a string, number, boolean,
// object or array; the typed registry on the application side keeps
// the shape honest.
// -----------------------------------------------------------------

model Setting {
  key             String   @id
  value           Json
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -----------------------------------------------------------------
// Audit log (Phase 5) — who-did-what across admin actions.
// -----------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  // Snapshot the actor's email at log time so the row stays readable
  // after the user is deleted/renamed.
  actorUserId String?
  actorEmail  String?
  // Free-form so we can audit anything: 'product', 'order', 'staff',
  // 'setting', 'webhook', etc.
  entityType  String
  entityId    String?
  // 'create' / 'update' / 'delete' / domain-specific ('refund.recorded',
  // 'order.status_changed', 'staff.created'...).
  action      String
  // Structured diff or context payload — { before, after, ... }.
  changes     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

// -----------------------------------------------------------------
// Webhooks (Phase 5) — outbound HTTP callbacks for in-process events.
// -----------------------------------------------------------------

model Webhook {
  id        String   @id @default(cuid())
  name      String
  url       String
  // Subscribed event names (e.g. 'order.placed', 'order.refunded').
  // Wildcard '*' subscribes to every event.
  events    String[]
  // HMAC-SHA256 secret used to sign delivery payloads. Generated at
  // create time, returned once, hashed/stored at rest? For v1 we
  // store the raw secret since it's per-webhook and only admins
  // can read it; tighten later if needed.
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([isActive])
}

/// Phase 11.3 (audit H3) — inbound-webhook replay guard.
///
/// Indexed by (provider, bodyHash) — a SHA-256 of the raw webhook
/// body. The service layer INSERTs a row inside the same transaction
/// that flips the order; a unique-constraint violation means we've
/// seen this exact webhook before and short-circuit the work.
///
/// Why hash the whole body instead of using `gatewayRef`:
///  - Same gatewayRef can have multiple legitimate events (PENDING
///    → SUCCEEDED). We only want to reject IDENTICAL deliveries.
///  - Body mutation invalidates the gateway signature anyway, but
///    this is defence-in-depth: even a signature-validation bug
///    would still be caught by the dedupe.
model InboundWebhookEvent {
  id         String   @id @default(cuid())
  /// 'squad', 'flutterwave', etc.
  provider   String
  /// 64-char SHA-256 hex of the raw webhook body bytes.
  bodyHash   String
  /// What we did with it — for audit / debugging.
  outcome    String
  receivedAt DateTime @default(now())

  @@unique([provider, bodyHash])
  @@index([receivedAt])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  webhookId     String
  webhook       Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType     String
  payload       Json
  // null until first attempt completes. statusCode 0 = transport error.
  statusCode    Int?
  responseBody  String?   @db.Text
  attempts      Int       @default(0)
  succeededAt   DateTime?
  failedAt      DateTime?
  // Set when a failed delivery is queued for retry. Worker picks up
  // rows where succeededAt IS NULL AND nextAttemptAt <= NOW().
  nextAttemptAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([webhookId])
  @@index([eventType])
  @@index([createdAt])
  @@index([nextAttemptAt])
}

// -----------------------------------------------------------------
// Notifications (Phase 8) — log of every transactional message
// (email/SMS/push) we send, plus password reset tokens.
// -----------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id                String              @id @default(cuid())
  userId            String?
  channel           NotificationChannel @default(EMAIL)
  // e.g. 'order.confirmed', 'order.shipped', 'password.reset', 'welcome'
  type              String
  recipient         String
  subject           String?
  // Adapter's outbound message id (Resend's id, Twilio's SID, etc.).
  providerMessageId String?
  status            NotificationStatus  @default(PENDING)
  error             String?             @db.Text
  // Free-form context — useful for "Resend" replays without re-fetching
  // every related entity from the DB.
  context           Json                @default("{}")
  sentAt            DateTime?
  /// Tracker #49 — denormalised mirrors of EmailEvent rows so the
  /// admin notifications list can render "opened? clicked? bounced?"
  /// without aggregating the event log on every request. The full
  /// history (including multi-opens / multi-clicks) lives in
  /// EmailEvent rows linked by providerMessageId.
  deliveredAt       DateTime?
  firstOpenedAt     DateTime?
  lastOpenedAt      DateTime?
  openCount         Int                 @default(0)
  firstClickedAt    DateTime?
  lastClickedAt     DateTime?
  clickCount        Int                 @default(0)
  /// Hard bounce (invalid mailbox, blocked domain). Sets status to
  /// FAILED. Soft delays don't populate this — they retry.
  bouncedAt         DateTime?
  bounceReason      String?             @db.Text
  /// Spam complaint from the recipient's mail client.
  complainedAt      DateTime?
  events            EmailEvent[]
  createdAt         DateTime            @default(now())

  @@index([userId])
  @@index([providerMessageId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

/// Tracker #49 — per-event row for delivery / open / click / bounce
/// / complaint signals received from the email provider (Resend
/// today, others later). The Notification row keeps a denormalised
/// summary (first/last open + count etc.) so common admin queries
/// don't touch this table; raw events live here for analytics + ML.
enum EmailEventType {
  SENT
  DELIVERED
  DELIVERY_DELAYED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
}

model EmailEvent {
  id                String         @id @default(cuid())
  /// FK to Notification; nullable in the rare case Resend posts an
  /// event we have no record of (test sends, deleted notifications,
  /// pre-Tracker-#49 sends with no providerMessageId).
  notificationId    String?
  notification      Notification?  @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  /// Resend's email id, copied from the webhook payload. Lets us
  /// match against Notification.providerMessageId even when the
  /// Notification row hasn't been linked yet.
  providerMessageId String
  type              EmailEventType
  /// When the event occurred, per Resend's `created_at` field.
  /// Falls back to row's createdAt if the payload didn't include one.
  occurredAt        DateTime
  /// Click events carry the URL the recipient clicked. Other types
  /// leave this null.
  clickedUrl        String?
  /// Bounce events carry the reason / classification (hard vs soft).
  bounceType        String?
  bounceReason      String?        @db.Text
  /// Raw webhook payload kept for debugging + future enrichment.
  rawPayload        Json           @default("{}")
  createdAt         DateTime       @default(now())

  @@index([providerMessageId])
  @@index([notificationId])
  @@index([type, occurredAt])
}

// ------------------------------------------------------------------
// Phase 10.7 — Featured Placements
//
// Lets admins manually decide where each product appears across the
// site (homepage shelves, hero, curated landing pages, CMS pages…)
// in addition to the auto-derived behaviours (on-sale, new arrival,
// category, country). Every row is a (product, placement-key) pairing
// with optional time window and country scope.
//
// Placement keys come from a hardcoded registry plus dynamic
// `cms:<page-slug>` keys for CMS-page features.
// ------------------------------------------------------------------

model ProductPlacement {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// e.g. "homepage_hero", "for_her", "cms:black-friday"
  placement String
  /// Lower number = higher priority. Used to sort within a placement.
  sortOrder Int       @default(100)
  /// Optional time window. NULL = no constraint on that side.
  startsAt  DateTime?
  endsAt    DateTime?
  /// Optional country scope. Empty array = global (all countries).
  /// Otherwise only requests with a matching `country` code see this.
  countries String[]  @default([])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([productId, placement])
  @@index([placement, sortOrder])
}

// ------------------------------------------------------------------
// Phase 10.8 — Shelf Manager
//
// One row per placement key. Stores the *container* config — title,
// rows, columns, enabled flag — that the storefront uses when rendering
// that shelf. Per-product membership lives in ProductPlacement; Shelf
// is just the wrapper config so non-engineers can change "show 1 row"
// vs "show 3 rows", rename a shelf, or hide it from admin.
// ------------------------------------------------------------------

model Shelf {
  id        String   @id @default(cuid())
  /// Matches a key from PLACEMENT_REGISTRY or "cms:<page-slug>".
  key       String   @unique
  /// Storefront-facing heading shown above the products.
  title     String
  /// Optional sub-heading line under the title.
  subtitle  String?
  /// Number of rows of products to render. limit = rows * cols.
  rows      Int      @default(1)
  /// Columns at the widest breakpoint. Storefront still uses
  /// responsive col-count for narrower screens.
  cols      Int      @default(6)
  /// When false the storefront skips the shelf entirely.
  enabled   Boolean  @default(true)
  /// Phase 10.8b — country-rule auto-fill. When set (non-null,
  /// non-empty), the storefront fills the shelf from these rules
  /// instead of explicit picks. Format:
  ///   [{ "country": "ZA", "count": 6 }, { "country": null, "count": 6 }]
  /// `country: null` means any country. Rows render in the order
  /// they appear in the array.
  countryRows Json?
  /// Phase 11 — category-rule auto-fill. Array of category slugs
  /// that source the shelf's products. When non-empty AND
  /// countryRows is null, the shelf auto-fills with the latest
  /// in-stock products from these categories (and their
  /// subcategories — leaf-wins rule). Country-rule still wins when
  /// both are set; explicit picks are the fallback.
  ///
  /// Scalable pattern for category-themed home shelves (Mobile
  /// Phase 3): admin creates "Groceries" shelf with
  /// categoryAutoFill: ["groceries"]; new products in that
  /// category appear without admin re-curating.
  categoryAutoFill String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------------------
// Phase 10.6 — CMS / Page Builder
//
// Marketing-editable static-ish pages. Blocks JSON tree is rendered by
// the storefront's catch-all `[...slug]` route. Slug is the URL path
// after the domain, e.g. "about-us" or "deals/black-friday".
// ------------------------------------------------------------------

model CmsPage {
  id              String    @id @default(cuid())
  // URL path — unique. No leading slash. Use slashes for nesting.
  slug            String    @unique
  title           String
  // SEO meta description.
  metaDescription String?   @db.Text
  // Body — array of blocks (hero / rich-text / image / image-grid / cta /
  // product-carousel). Renderer in components/cms/render-page.tsx
  blocks          Json      @default("[]")
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished])
}

// ------------------------------------------------------------------
// Phase 10.5 — Business Rules Engine (Principle #3)
//
// Generic if/then rules editable from admin. Each rule is scoped to
// where it runs (cart, order, fulfilment, …). The engine takes a
// context object and a scope; returns the merged actions of all
// matching rules in priority order.
//
// Conditions JSON is a tree of simple matchers (eq/neq/gte/lte/in/all/any).
// Actions JSON is a free-form map the host module interprets — e.g.
// `{ freeShipping: true }`, `{ discountPercent: 10 }`,
// `{ requireApproval: true, reason: "high-value" }`.
//
// Pragmatic scope today: rules are EVALUATED but their actions are only
// honored in modules that opt in. New rule callers land progressively.
// ------------------------------------------------------------------

model BusinessRule {
  id          String   @id @default(cuid())
  scope       String // "cart", "order", "fulfilment", "discount", …
  key         String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  // Lower number = evaluated first.
  priority    Int      @default(100)
  // Tree of matchers — see service/rules.ts for the DSL.
  conditions  Json     @default("{}")
  // Free-form actions object. Host module decides what fields it cares
  // about (e.g. cart cares about `freeShipping` + `discountPercent`).
  actions     Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scope, key])
  @@index([scope, isActive, priority])
}

// ------------------------------------------------------------------
// Phase 10.4 — Feature Flags (Principle #2)
//
// Each flag has a default value (used when no targeting rule fires)
// plus a list of targeting rules evaluated in order. The first matching
// rule wins. Targeting context comes from the API request (userId,
// userRole, country) and is opaque to the engine — rules use json-logic
// or a tiny custom DSL stored in `targetingRules`.
//
// Rule shape:
//   [
//     { match: { userRole: "ADMIN" }, value: true },
//     { match: { country: ["NG","KE"] }, value: true },
//     { match: { rolloutPercent: 10 }, value: true },
//   ]
// ------------------------------------------------------------------

model FeatureFlag {
  id             String   @id @default(cuid())
  // Stable key referenced from code (e.g. `useFlag('new_checkout')`).
  key            String   @unique
  name           String
  description    String?  @db.Text
  // Default boolean; non-boolean variants land in a future iteration.
  defaultValue   Boolean  @default(false)
  // Ordered list of targeting rules — first match wins.
  targetingRules Json     @default("[]")
  // Master kill-switch. When false the flag always returns
  // defaultValue without evaluating rules.
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([key])
}

// ------------------------------------------------------------------
// Phase 10.3 — Email Template Editor (Principle #4 Schema-Driven Design)
//
// One row per transactional email type ("order.confirmed",
// "user.welcome", …). The body is a JSON tree of blocks
// (`{type:'Heading',text:'…'}`, `{type:'Button',label:'…',href:'{trackUrl}'}`,
// `{type:'Row',children:[…]}`, …). At send time the dispatcher renders
// the tree using `templates/render-blocks.tsx` and ships it via Resend.
//
// Templates can reference template variables via `{like_this}` syntax;
// the dispatcher substitutes from the event payload at send time.
// ------------------------------------------------------------------

model EmailTemplate {
  id        String   @id @default(cuid())
  // Unique event key — must match a key the dispatcher emits
  // ("order.confirmed", "user.welcome", "password.reset", …).
  type      String   @unique
  // Human-readable name shown in admin.
  name      String
  // Subject line — supports `{variable}` substitution.
  subject   String
  // Block tree — see render-blocks.tsx for the supported block types.
  // Authored from /admin/email-templates.
  body      Json     @default("[]")
  // Marketing-editable preview text (the snippet shown in the inbox
  // list under the subject). Optional.
  preview   String?
  // When false the dispatcher falls back to the hardcoded TSX
  // template — handy if someone breaks a template in admin.
  isActive  Boolean  @default(true)
  // Soft system flag: templates seeded from code start as system.
  // Admin can edit but not delete them.
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// ------------------------------------------------------------------
// Phase 10.2 — Payment Gateway Registry (Principle #6 Pluggable Providers)
//
// One row per configured gateway. The `provider` column points at a
// code-side factory (`squad`, `paystack`, `stub`, ...). Adding a brand-new
// kind of provider takes one new file in `payments/providers/` plus a
// registry entry; the rest is data.
// ------------------------------------------------------------------

/// Tracker #46 — customer-facing payment method config. One row per
/// method the customer sees on /checkout/payment. Type-specific
/// data (USSD codes, mobile-money providers, crypto wallets, POD
/// cities/fee) lives on the `details` Json so adding new method
/// variants doesn't require a schema migration. Bank transfer
/// accounts live in a separate `PaymentBankAccount` table because
/// they're multi-row per method (one per currency/country).
enum PaymentMethodCode {
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
  USSD
  CRYPTO
  PAY_ON_DELIVERY
}

model PaymentMethodConfig {
  id          String              @id @default(cuid())
  code        PaymentMethodCode   @unique
  label       String
  description String
  /// Icon key consumed by the storefront switch
  /// (credit-card / smartphone / building-2 / hash / bitcoin / truck).
  icon        String
  isActive    Boolean             @default(true)
  isPopular   Boolean             @default(false)
  sortOrder   Int                 @default(0)
  /// Per-method bag:
  ///   CARD            → {} (gateway-driven; nothing here for now)
  ///   MOBILE_MONEY    → { providers: [{ code, name, countries:[] }] }
  ///   USSD            → { codes: { "Access Bank": "*901*000*[Amount]#", ... } }
  ///   CRYPTO          → { wallets: [{ coin: 'BTC', address: '...', label? }] }
  ///   PAY_ON_DELIVERY → { feeNgn: 500, cities: ['Lagos','Nairobi','Accra'] }
  details     Json                @default("{}")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([isActive, sortOrder])
}

/// Tracker #46 — Customer-visible bank-transfer account. Multiple
/// rows allowed; storefront picks the row matching the order's
/// currency (and country if specified). Only one row per
/// (currency, country) is needed in practice, but we don't enforce
/// uniqueness so the admin can stage replacements.
model PaymentBankAccount {
  id            String  @id @default(cuid())
  bankName      String
  accountName   String
  accountNumber String
  /// ISO 4217 — drives which account is shown at checkout for the
  /// order's currency. "NGN" for Naira accounts, "GHS" for Ghana, etc.
  currency      String
  /// Optional ISO-2 country restriction. Null = available for any
  /// country (matched purely on currency).
  country       String?
  /// Free-form swift / sort code / bank instructions copy.
  instructions  String?
  isActive      Boolean @default(true)
  sortOrder     Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, currency])
  @@index([currency, country])
}

model PaymentGatewayConfig {
  id          String   @id @default(cuid())
  // Stable code key that maps to a registered factory class.
  provider    String
  // Human-readable label shown to the customer at checkout
  // (e.g. "Card / Squad", "Bank Transfer (Paystack)").
  label       String
  // sandbox / live — providers usually have separate base URLs + keys.
  environment String   @default("sandbox")
  // Hot toggle from admin without redeploying.
  isActive    Boolean  @default(true)
  // Lower number = higher in the checkout list.
  priority    Int      @default(100)
  // Currencies this config can process (ISO 4217). Storefront filters
  // to gateways that accept the order's currency.
  currencies  String[] @default(["NGN"])
  // Provider-specific credentials. JSON so each provider can store
  // whatever shape it needs (Stripe has publishableKey + secretKey,
  // Paystack has secretKey + publicKey, M-Pesa has shortCode + ...).
  // NEVER returned to non-admin clients.
  credentials Json     @default("{}")
  // Free-form non-secret metadata (display order, supported channels,
  // marketing copy) shown alongside the picker on the storefront.
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, priority])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  // Bcrypt-hashed token. The plaintext is only sent in the email; we
  // never store it. Confirm endpoint compares incoming plaintext
  // against this hash.
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Phase 11.3 (audit H7) — anti-replay nonce for Google sign-in.
/// Server-issued single-use challenge: client requests one before
/// triggering the GIS popup, passes it as the OIDC `nonce` so Google
/// embeds it in the ID token, and the verify endpoint atomically
/// consumes the row. A captured ID token cannot be replayed because
/// its nonce row is already marked consumed (or expired, 10-minute
/// TTL). Cleanup of expired/consumed rows is best-effort — the
/// unique index on `nonce` is what enforces single-use.
model GoogleAuthChallenge {
  id          String    @id @default(cuid())
  nonce       String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?

  @@index([expiresAt])
}

/// Saved delivery addresses on the customer account. Used by
/// `/account/addresses` for management and by `/checkout/shipping`
/// to populate the address picker. Only one address per user can
/// be `isDefault: true` at a time — exclusivity is enforced in the
/// addresses service (not the schema; Postgres can't express
/// "unique-per-user-where-true" without a partial unique index,
/// and we don't want to fight the seed-data flow).
model UserAddress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserAddresses", fields: [userId], references: [id], onDelete: Cascade)
  /// Recipient's full name on the parcel — may differ from the
  /// account holder (gift orders, household members).
  fullName    String
  /// E.164 phone for the courier to reach the recipient.
  phone       String
  /// Free-form street + apartment line. Single field for simplicity;
  /// future expansion to (line1 + line2) can split this column.
  addressLine String
  city        String
  /// 2-letter ISO country code, matches the storefront's COUNTRIES list.
  country     String
  /// Optional admin-only label so the customer can name the address
  /// ("Home", "Lagos office", etc.). Surfaced on the address card.
  label       String?
  /// Exactly one address per user can be true. The service ensures
  /// exclusivity in a transaction.
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
}

/// One row per (user, product) the customer has favourited. The
/// uniqueness constraint means an idempotent POST — a duplicate add
/// is a no-op rather than a 409. Removing is a DELETE by productId
/// scoped to the signed-in user.
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserWishlist", fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

/// Where a price-change row came from. Matches every code path
/// that calls `applyPriceChange()`. Used in the audit drawer to
/// show "Bulk update by Magnus on 2026-05-11" vs "Scheduled
/// rollback".
enum PriceChangeSource {
  /// Single-field inline edit on /admin/products list.
  INLINE
  /// Bulk re-price action (set/+%/-%).
  BULK
  /// CSV import.
  CSV
  /// Scheduled flip executed by the cron worker (PR 4).
  SCHEDULED
  /// Edited via the full /admin/products/[id] form.
  MANUAL
  /// "Undo" / "Revert to this row" from the history drawer.
  REVERT
}

/// Append-only audit log of every price change. One row per
/// price-mutating event; `applyPriceChange()` is the only writer
/// (no direct inserts from controllers or scripts). Snapshots
/// both fields (price + comparePrice) so the history is
/// self-contained — readers don't need to look at the Product
/// row to know what the price was at any point in time.
model ProductPriceChange {
  id               String            @id @default(cuid())
  productId        String
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Price before the change (NGN whole units). Null for the
  /// very first row of a newly-created product — there was no
  /// "old" value.
  oldPrice         Int?
  newPrice         Int
  oldComparePrice  Int?
  newComparePrice  Int?
  /// User that triggered the change. Null only for SCHEDULED
  /// rows (the cron has no acting user — admin who *scheduled*
  /// it is on the ProductPriceSchedule row in PR 4).
  changedById      String?
  changedBy        User?             @relation("PriceChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  source           PriceChangeSource
  /// Optional free-form note ("Q3 supplier price hike",
  /// "Black Friday opening price"). Surfaces in the history
  /// drawer.
  reason           String?
  createdAt        DateTime          @default(now())

  @@index([productId, createdAt])
  @@index([changedById])
}

// ------------------------------------------------------------------
// Phase 10.1 — Custom Field Registry (Principle #4 Schema-Driven Design)
//
// Lets non-devs add new product attributes (and later: order/user
// attributes) without code changes. A `CustomFieldDef` row defines the
// shape (name, type, validation); per-record values land in the host
// model's existing `attributes` Json column under the same key. No
// migration required to add a new field.
// ------------------------------------------------------------------

enum CustomFieldScope {
  PRODUCT
  ORDER
  USER
}

enum CustomFieldType {
  TEXT // single-line text
  LONGTEXT // multi-line / textarea
  NUMBER // integer or decimal — uses min/max in `options`
  BOOLEAN // checkbox
  URL // generic URL — rendered as link
  VIDEO // YouTube / Vimeo / direct mp4 URL — rendered as embed
  IMAGE // image URL — rendered as <Image>
  SELECT // dropdown — choices in `options.choices: string[]`
  JSON // raw JSON for power users
  RICHTEXT // HTML/markdown body
}

model CustomFieldDef {
  id          String           @id @default(cuid())
  scope       CustomFieldScope
  // Stable key used inside the host's `attributes` JSON. Lowercase,
  // underscored. Once set, do not change — old records keep using it.
  key         String
  // Human-readable name shown in admin and on the storefront.
  label       String
  // Optional helper text shown under the field in admin.
  description String?
  type        CustomFieldType
  required    Boolean          @default(false)
  // Display weight — lower = higher up. Used for both admin form and
  // storefront render order.
  sortOrder   Int              @default(100)
  // Type-specific config. Examples:
  //   SELECT  → { choices: ["red","blue"] }
  //   NUMBER  → { min: 0, max: 100, step: 1 }
  //   VIDEO   → { provider: "youtube"|"vimeo"|"mp4" } (auto-detected if omitted)
  //   IMAGE   → { aspectRatio: "16:9" }
  options     Json             @default("{}")
  // When false the def is hidden from admin forms but old values are
  // preserved on records — soft-delete pattern.
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([scope, key])
  @@index([scope, isActive, sortOrder])
}

// -----------------------------------------------------------------
// Page builder (CMS Phase 1) — every storefront page becomes an
// ordered list of typed PageSection records. The renderer fetches
// them and dispatches each section to a component matching its
// `type` discriminator. Mirrors how Webflow/Builder.io structure
// dynamic pages, kept deliberately small (typed sections, not a
// free canvas) so admins can't break the layout.
// -----------------------------------------------------------------

model Page {
  id          String         @id @default(cuid())
  /// URL identifier — "home", "deals", "new-arrivals", "shop/groceries".
  /// No leading slash; slashes allowed for nesting.
  slug        String         @unique
  /// Display name shown in /admin/pages.
  title       String
  description String?
  publishedAt DateTime?
  sections    PageSection[]
  revisions   PageRevision[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model PageSection {
  id          String    @id @default(cuid())
  pageId      String
  page        Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  /// Section discriminator — see SECTION_TYPES in API for the registry.
  /// Examples: "hero", "product-grid", "category-shelf", "image-banner",
  /// "rich-text", "africa-map", "newsletter", "trust-bar", "quotation-form".
  type        String
  /// Sort order — lower renders earlier. Reordered via drag in admin.
  position    Int       @default(0)
  /// Kill switch — set to false to hide without deleting.
  visible     Boolean   @default(true)
  /// Editable display heading (may be null for sections that own their
  /// own copy, e.g. hero slides).
  headline    String?
  subheadline String?
  /// Hex like "#0D1F4E" or palette key ("navy"/"amber"/...). The
  /// renderer maps palette keys to brand tokens; raw hex passes through.
  accentColor String?
  /// Type-specific config. Schema enforced by zod in the API layer
  /// per-section-type, never at the DB level (lets us add new types
  /// without migrations).
  config      Json      @default("{}")
  /// Pending edits (Phase 2 draft/publish). When non-null, admin
  /// preview reads this; storefront ignores it.
  draftConfig Json?
  /// Optional time window (Phase 2). Outside the window the section
  /// is hidden from the storefront (admin always sees it).
  startsAt    DateTime?
  endsAt      DateTime?
  /// Country targeting (Phase 2). Empty = global; otherwise only
  /// requests with a matching ISO-2 code in the geo cookie see it.
  countries   String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([pageId, position])
}

model PageRevision {
  id          String   @id @default(cuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  /// Snapshot of the entire section list as a JSON array. Used to
  /// revert the page to a prior state in one click. We keep the last
  /// 50 per page; older are pruned on save.
  snapshot    Json
  authorId    String?
  author      User?    @relation("PageRevisionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  /// Snapshot of author email at write time so the revision stays
  /// readable after the user is deleted/renamed.
  authorEmail String?
  /// Optional commit-message-style note ("Black Friday banner live").
  note        String?
  createdAt   DateTime @default(now())

  @@index([pageId, createdAt(sort: Desc)])
}

// -----------------------------------------------------------------
// Image library (CMS Phase 2) — every R2 upload becomes a reusable
// asset with required alt text. Picker replaces ad-hoc URL fields
// across the admin UI.
// -----------------------------------------------------------------

model MediaAsset {
  id           String   @id @default(cuid())
  url          String   @unique
  filename     String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  /// Required for SEO + a11y. Admin must set on upload.
  alt          String
  uploadedById String?
  uploadedBy   User?    @relation("MediaAssetUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

// -----------------------------------------------------------------
// Blog (separate from CmsPage long-form). BlogPosts are indexed in
// the sitemap, syndicated via /rss.xml, and emit Article JSON-LD.
// -----------------------------------------------------------------

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model BlogPost {
  id              String         @id @default(cuid())
  slug            String         @unique
  title           String
  excerpt         String?        @db.Text
  /// Body HTML. Authored via TipTap-style rich text editor in admin.
  /// Sanitised on render.
  content         String         @db.Text
  heroImage       String?
  heroImageAlt    String?
  authorId        String?
  author          User?          @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  /// Snapshot of the author's display name at the time of write — so
  /// posts keep attribution after staff turnover.
  authorName      String?
  status          BlogPostStatus @default(DRAFT)
  /// Set when status flips to PUBLISHED. For SCHEDULED posts this is
  /// the future date — a cron flips status at that time.
  publishedAt     DateTime?
  // SEO overrides — falls back to title/excerpt when blank.
  metaTitle       String?
  metaDescription String?        @db.Text
  ogImage         String?
  /// Free-form tags for filtering + cross-linking related posts.
  tags            String[]       @default([])
  /// Auto-computed on save (200 wpm) for the "X min read" badge.
  readingTimeMin  Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([slug])
}

// -----------------------------------------------------------------
// Intern image-update workflow.
//
// Each ProductImageSubmission is one (intern, product) attempt: front
// + back + side images plus optional extras. Submissions go into a
// PENDING_REVIEW queue; admin approves (publishes images to
// Product.images, intern gets paid) or rejects with a reason. Rejected
// submissions can be re-submitted — that creates a new row, leaving
// the rejected one as history. The intern's payable count is just
// `WHERE internId = me AND status = APPROVED`.
// -----------------------------------------------------------------

enum ImageSubmissionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model ProductImageSubmission {
  id              String                @id @default(cuid())
  productId       String
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  internId        String
  intern          User                  @relation("InternSubmissionAuthor", fields: [internId], references: [id], onDelete: Cascade)
  status          ImageSubmissionStatus @default(PENDING_REVIEW)
  /// Image roles. Originally all three were required; loosened to
  /// optional because some products legitimately don't have all 3
  /// angles (flat items, small bottles where back == side, etc.).
  /// The submit endpoint enforces "at least one product image" via
  /// the zod schema instead of the DB.
  frontImageUrl   String?
  backImageUrl    String?
  sideImageUrl    String?
  additionalImages String[]             @default([])
  /// Brand / company logo. Required at the schema level (see
  /// submitImagesBodySchema) so every approved submission gives the
  /// product page's "About the brand" section an image to render.
  brandImageUrl   String?
  brandImageAlt   String?
  /// Filled when status flips to REJECTED. Surfaced to the intern in
  /// their queue so they know what to fix.
  rejectionReason String?
  reviewedById    String?
  reviewedBy      User?                 @relation("InternSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  /// Pay rate snapshot in NGN at submission time. Locked here so a
  /// later rate change doesn't retroactively change what's owed for
  /// already-approved work.
  payRate         Int                   @default(0)
  /// Set when this submission has been rolled into an InternPayout
  /// (either still DRAFT or already PAID). Null = approved but not
  /// yet attached to a payout → counts as "unpaid, payable". The
  /// composite index below keeps the unpaid-approved query fast.
  payoutId        String?
  payout          InternPayout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([internId, status])
  @@index([productId])
  @@index([status, createdAt])
  @@index([internId, status, payoutId])
}

// ------------------------------------------------------------------
// Intern image-work payouts (Tracker #50, 2026-05-18)
//
// One InternPayout row per payday for one intern. Many approved
// submissions roll into a payout via ProductImageSubmission.payoutId.
//
// Lifecycle:
//   DRAFT    paidAt == null         — admin built the batch but money
//                                     hasn't moved yet. Cancel returns
//                                     the submissions to "unpaid" by
//                                     nulling payoutId in a tx.
//   PAID     paidAt != null         — admin marked the batch paid
//                                     (off-platform bank/MM transfer)
//                                     and recorded externalRef.
//
// `totalNgn` and `submissionCount` are SNAPSHOTS taken when the
// draft is created. We don't recompute them later — that would
// drift if a contributor edits payRate on an already-paid submission.
// ------------------------------------------------------------------
model InternPayout {
  id              String                  @id @default(cuid())
  internId        String
  intern          User                    @relation("InternPayoutContractor", fields: [internId], references: [id], onDelete: Cascade)
  /// Sum of payRate across every submission attached to this payout
  /// at the time of draft creation. Frozen.
  totalNgn        Int
  /// Number of submissions covered. Denormalized for list rendering.
  submissionCount Int
  /// Window the admin used when generating the payout. Stored so
  /// finance can reprint the CSV for a given payday.
  windowFrom      DateTime?
  windowTo        DateTime?
  /// Set when the admin clicks "Mark paid". Null while still DRAFT.
  paidAt          DateTime?
  /// Bank transfer ID / Mobile Money reference / payment slip number.
  externalRef     String?
  /// Free-text note (e.g. "Paid via Kuda — May payroll").
  note            String?
  createdAt       DateTime                @default(now())
  createdById     String?
  createdBy       User?                   @relation("InternPayoutCreator", fields: [createdById], references: [id], onDelete: SetNull)
  submissions     ProductImageSubmission[]
  /// Full-product submissions rolled into this payout (2026-05-24).
  /// A payout can cover both image work and product work for one
  /// intern in the same payday.
  productSubmissions ProductSubmission[]

  @@index([internId, paidAt])
  @@index([paidAt])
}

// ------------------------------------------------------------------
// Full-product intern submissions (2026-05-24)
//
// Interns with the `products.submit` capability can draft a complete
// product (name, description, price, category, images, custom
// fields) for review. A reviewer with `intern.review` approves —
// which CREATES the live Product and stamps the submission payable —
// or rejects with a reason for rework. Mirrors ProductImageSubmission
// so the same review + payout machinery applies. Pay uses the same
// flat `intern.pay_rate_ngn` Setting, snapshotted per submission.
// ------------------------------------------------------------------
model ProductSubmission {
  id              String                @id @default(cuid())
  internId        String
  intern          User                  @relation("ProductSubmissionAuthor", fields: [internId], references: [id], onDelete: Cascade)
  status          ImageSubmissionStatus @default(PENDING_REVIEW)

  // --- Staged product fields (become the live Product on approval) ---
  name            String
  /// Intern-supplied or auto-slugified at submit time. Uniqueness is
  /// only enforced on the real Product at approval, so two pending
  /// drafts can share a slug until one is approved.
  slug            String
  brand           String?
  shortDescription String?
  description     String?
  ingredients     String?
  /// NGN whole units.
  price           Int
  comparePrice    Int?
  /// 2-letter ISO origin.
  origin          String?
  weightKg        Float?
  images          String[]              @default([])
  /// Bundles / custom fields / specifications — same JSON shape the
  /// Product.attributes column uses. Validated at approval time.
  attributes      Json                  @default("{}")
  /// Stored as the category SLUG; resolved to a category id when the
  /// Product is created on approval (the category may not exist yet
  /// at submit time if an admin is still setting up the tree).
  categorySlug    String?

  /// Filled when REJECTED so the intern sees what to fix.
  rejectionReason String?
  reviewedById    String?
  reviewedBy      User?                 @relation("ProductSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  /// The live Product created when this submission was approved.
  /// Null while pending/rejected. Plain id (no FK) so deleting the
  /// product later doesn't block — this is an audit trail.
  createdProductId String?

  /// Pay rate snapshot in NGN at submit time — same flat rate as
  /// image submissions. Locked so later rate changes don't rewrite
  /// owed pay. Consumed by the payout flow (PR 1b).
  payRate         Int                   @default(0)
  payoutId        String?
  payout          InternPayout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([internId, status])
  @@index([status, createdAt])
  @@index([internId, status, payoutId])
}

// ------------------------------------------------------------------
// Continental Rewards — Afrizone Coin loyalty program
// (Tracker #44, design locked 2026-05-12)
//
// One Account per User, created on the first PAID order. Coin balance
// is *cached* on the Account row for fast reads but the *source of
// truth is the ledger sum* — any time a Transaction row lands, the
// cache is recomputed in the same DB transaction.
//
// The ledger is append-only. No `UPDATE` or `DELETE` queries on
// LoyaltyTransaction rows anywhere in the codebase. Refunds, expiries,
// admin adjustments are all *new* rows with the appropriate type.
//
// LoyaltyConfig is a singleton (one row, `id = 1`) holding every
// admin-tunable knob. Each change writes to the central AuditLog.
// ------------------------------------------------------------------

enum LoyaltyTier {
  /// Continental Blue — entry tier. Every customer who has made
  /// a first paid order is at least Blue.
  BLUE
  /// Continental Gold — rolling 12-month spend ≥ tier2Gold threshold.
  GOLD
  /// Continental VIP — rolling 12-month spend ≥ tier3Vip threshold.
  VIP
  /// Continental Ambassador — rolling 12-month spend ≥ tier4Ambassador threshold.
  AMBASSADOR
  /// Continental Dorime — rolling 12-month spend ≥ tier5Dorime threshold.
  DORIME
}

enum LoyaltyTransactionType {
  /// One-time bonus on auto-enrollment (first paid order). Locked by
  /// `LoyaltyAccount.enrolledAt`; cannot double-fire.
  WELCOME_BONUS
  /// Coins earned for a paid order, per the tier's per-order rate.
  EARN
  /// Coins applied to an order at checkout. delta < 0.
  REDEEM
  /// Reversal when a previously-earning order is refunded. delta < 0.
  /// `causeOrderId` points at the refunded order.
  REFUND_REVERSAL
  /// Reversal of a REDEEM when its order is refunded — returns the
  /// coins the customer paid with. delta > 0.
  REDEEM_REFUND
  /// Cron-issued expiry of coins past their `expiresAt`. delta < 0.
  /// FIFO: oldest non-expired coins debited first.
  EXPIRY
  /// Manual admin intervention (correction, goodwill credit, fraud
  /// clawback). `causeAdminId` + `reason` required.
  ADMIN_ADJUSTMENT
}

/// One row per customer enrolled in the loyalty program. Auto-
/// created on first paid order. `coinBalance` and `currentTier` are
/// caches recomputed from the ledger on every mutation; the
/// `lifetime*` fields are convenience counters for analytics +
/// the rewards-page UI.
model LoyaltyAccount {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  user                  User                   @relation("UserLoyalty", fields: [userId], references: [id], onDelete: Cascade)
  /// Cached current coin balance. Source of truth is the ledger.
  coinBalance           Int                    @default(0)
  /// Cached tier. Recomputed daily by the cron based on rolling
  /// 12-month spend, and on-write when a paying order lands.
  /// 2026-05-16 — tier is now monotonic: the cron upgrades but never
  /// downgrades. Admin can downgrade manually with a reason (see
  /// `tierProtected` + `lastDowngradedAt` below).
  currentTier           LoyaltyTier            @default(BLUE)
  /// 2026-05-16 — true once the account has reached any tier; the
  /// cron then never auto-downgrades. Set the first time `currentTier`
  /// rises above BLUE. Reset only via admin manual downgrade.
  tierProtected         Boolean                @default(false)
  /// 2026-05-16 — set when an admin manually moves the customer to a
  /// lower tier. The audit reason lives on a ledger row of type
  /// ADMIN_ADJUSTMENT, not here; this column is a fast denorm "was
  /// this account ever downgraded".
  lastDowngradedAt      DateTime?
  /// Lifetime totals — only ever grow. Used on /account/rewards
  /// and for admin analytics.
  lifetimeCoinsEarned   Int                    @default(0)
  lifetimeCoinsRedeemed Int                    @default(0)
  /// Locked once. Welcome-bonus checks this — never re-fires.
  enrolledAt            DateTime               @default(now())
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  transactions          LoyaltyTransaction[]

  @@index([currentTier])
}

/// Append-only ledger. `applyLoyaltyTransaction()` in the service is
/// the only writer. balanceAfter is recorded on every row so the
/// rewards page can render a running balance without re-summing the
/// whole history each render. `expiresAt` is set on `WELCOME_BONUS`
/// and `EARN` rows only; `expiredAt` is set when the expiry cron
/// issues an `EXPIRY` row for these.
model LoyaltyTransaction {
  id            String                 @id @default(cuid())
  accountId     String
  account       LoyaltyAccount         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  /// Positive = added to balance, negative = removed.
  delta         Int
  /// Running balance after this row landed. Same value as
  /// `LoyaltyAccount.coinBalance` at the moment this row was
  /// inserted.
  balanceAfter  Int
  type          LoyaltyTransactionType
  /// Optional: order that caused this row. Set for EARN, REDEEM,
  /// REFUND_REVERSAL, REDEEM_REFUND.
  causeOrderId  String?
  /// Optional: admin user that triggered this row. Set for
  /// ADMIN_ADJUSTMENT only.
  causeAdminId  String?
  /// Free-form note. Required for ADMIN_ADJUSTMENT (audit). Optional
  /// elsewhere.
  reason        String?
  /// Set on EARN + WELCOME_BONUS rows. Null on everything else.
  /// When the expiry cron runs, rows where `expiresAt < now()` AND
  /// `expiredAt IS NULL` are eligible for an `EXPIRY` ledger entry.
  expiresAt     DateTime?
  /// Set on EARN + WELCOME_BONUS rows after the expiry cron has
  /// issued a matching EXPIRY row for them. Prevents double-expiry.
  expiredAt     DateTime?
  createdAt     DateTime               @default(now())

  @@index([accountId, createdAt])
  @@index([accountId, type, expiresAt])
  @@index([causeOrderId])
}

/// Singleton row (id = 1) holding every admin-tunable knob for the
/// loyalty program. Updates write to AuditLog via the admin endpoint.
model LoyaltyConfig {
  id                       Int      @id @default(1)
  // ---- Earn config ----
  baseEarnPerOrder         Int      @default(5)
  tierMultiplier           Float    @default(2.0)
  welcomeBonusCoins        Int      @default(20)
  // ---- Tier thresholds (NGN, rolling 12-month spend) ----
  tier2GoldThreshold       Int      @default(80000)
  tier3VipThreshold        Int      @default(500000)
  tier4AmbassadorThreshold Int      @default(1000000)
  tier5DorimeThreshold     Int      @default(10000000)
  // ---- Coin economics ----
  coinValueNgn             Int      @default(33)
  maxOrderRedeemPercent    Int      @default(50)
  minRedeemCoins           Int      @default(30)
  // ---- Expiry / window ----
  coinExpiryMonths         Int      @default(2)
  spendWindowMonths        Int      @default(12)
  // ---- 2026-05-16 Phase 2 perks ----
  /// Per-tier birthday-bonus coin amounts. Awarded on the
  /// customer's birth-month by the birthday cron when User.birthDate
  /// is set. 0 = disabled for that tier (Blue is 0 by default;
  /// Gold/VIP/Ambassador/Dorime get progressively more).
  birthdayBonusBlue        Int      @default(0)
  birthdayBonusGold        Int      @default(50)
  birthdayBonusVip         Int      @default(100)
  birthdayBonusAmbassador  Int      @default(200)
  birthdayBonusDorime      Int      @default(500)
  /// Weekend earn-rate multiplier. Saturdays award `floor(earn * x)`
  /// coins instead of `earn` for tiers in the
  /// `weekendBoostTiers` list. 1.0 = disabled.
  weekendEarnMultiplier    Float    @default(2.0)
  /// Tiers eligible for the weekend boost. Defaults to VIP+.
  /// Admin-editable so promotions ("Gold gets the boost this month")
  /// don't require a deploy.
  weekendBoostTiers        LoyaltyTier[] @default([VIP, AMBASSADOR, DORIME])
  /// Per-referrer cap on successful referrals counted per calendar
  /// month. Stops referral farming.
  maxReferralsPerMonth     Int      @default(5)
  /// Per-tier max coin payout cap for a single referral. The actual
  /// payout is `min(cap, ceil(refereeFirstOrderSubtotal * referralPercent / 100))`.
  referralCapBlue          Int      @default(50)
  referralCapGold          Int      @default(100)
  referralCapVip           Int      @default(200)
  referralCapAmbassador    Int      @default(300)
  referralCapDorime        Int      @default(500)
  /// Percentage of the referee's first-paid-order subtotal that
  /// becomes the referrer's coin payout (subject to the cap above).
  /// 5 = 5%. Stored as integer percent; the earn calc divides.
  referralPercent          Int      @default(5)
  /// Days the referral payout is held after the referee's first paid
  /// order. Lets the refund window clear before crediting the
  /// referrer; reversed if the order is refunded inside this window.
  referralHoldDays         Int      @default(14)
  /// Days the referee's "₦500 off first order" coupon is valid.
  refereeCouponValidDays   Int      @default(60)
  /// NGN discount the referee gets on their first order (one-time
  /// coupon generated at signup time, redeemable until the validity
  /// window above).
  refereeCouponNgn         Int      @default(500)
  updatedAt                DateTime @updatedAt
  updatedById              String?
}

/// 2026-05-16 — Phase 2 referral system. One row per (referrer,
/// referee) pair. Created at signup-attribution time; moves through
/// states as the referee places their first paid order and the
/// hold window clears.
///
/// Anti-gaming invariants enforced by the service:
///  - Referee user.id ≠ referrer user.id (no self-referral)
///  - Referee email + phone (when known) differ from the referrer's
///  - Per-month cap (`maxReferralsPerMonth`) is checked at payout
///    time, not signup, so spam referrals don't block legitimate
///    ones — they just don't pay out
///  - PAYOUT_SCHEDULED rows that never paid out (because the
///    referee's first order was refunded inside the hold window)
///    flip to REVERSED
enum ReferralStatus {
  /// Referee signed up with the referrer's code. Nothing has paid
  /// out yet. Referee gets a one-time coupon on first paid order
  /// (created lazily, not stored here).
  PENDING
  /// Referee's first paid order has landed. Referrer's payout is
  /// scheduled for `referralHoldDays` after `firstPaidOrderAt`.
  PAYOUT_SCHEDULED
  /// Cron has issued the referrer's coin payout. Terminal.
  PAID_OUT
  /// Referee's first paid order was refunded before the hold
  /// cleared, or the referral was caught by the per-month cap, or
  /// admin manually voided. Terminal.
  REVERSED
}

model Referral {
  id                   String         @id @default(cuid())
  /// The customer who shared the link.
  referrerUserId       String
  referrer             User           @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  /// The customer who signed up via the link.
  refereeUserId        String         @unique
  referee              User           @relation("ReferralReferee", fields: [refereeUserId], references: [id], onDelete: Cascade)
  /// Captured at signup so a later code change doesn't lose the
  /// attribution.
  referralCode         String
  status               ReferralStatus @default(PENDING)
  /// Referee's first PAID order. Null until the first paid order
  /// lands; set by the order.paid subscriber.
  firstPaidOrderId     String?
  firstPaidOrderAt     DateTime?
  /// Computed at payout-schedule time from the referee's first
  /// order subtotal × config.referralPercent, capped by the
  /// referrer's tier ceiling.
  scheduledCoinPayout  Int?
  /// When the cron should issue the payout. = firstPaidOrderAt +
  /// referralHoldDays. Cron daily checks this.
  scheduledPayoutAt    DateTime?
  /// Set when the referrer's coins land. Points at the
  /// LoyaltyTransaction row for traceability.
  paidOutAt            DateTime?
  payoutTransactionId  String?
  /// Set when the referral is voided (refunded inside hold,
  /// monthly cap hit, admin void). Includes the reason on the
  /// audit log (not stored here to keep the table narrow).
  reversedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([referrerUserId, status])
  @@index([scheduledPayoutAt])
  @@index([status])
}
