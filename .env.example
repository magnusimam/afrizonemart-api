# Server
NODE_ENV=development
PORT=4000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3737

# Database (Railway will inject this in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/afrizonemart

# Auth
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Observability
LOG_LEVEL=info
SENTRY_DSN=

# Frontend (for redirects, magic links etc.)
WEB_URL=http://localhost:3737
